# Generate both secrets before deployment, for example with:
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
UPDATE_AGENT_TOKEN=replace-with-a-separate-long-random-token

DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_HTTPS=0
DJANGO_TRUST_PROXY_SSL_HEADER=0
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_HSTS_PRELOAD=0

POSTGRES_DB=fliegerlager
POSTGRES_USER=fliegerlager
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgres://fliegerlager:replace-with-a-strong-database-password@db:5432/fliegerlager

APP_IMAGE=ghcr.io/lsf-wesel-rheinhausen/lsf-fliegerlager-webapp:latest
UPDATER_IMAGE=ghcr.io/lsf-wesel-rheinhausen/lsf-fliegerlager-webapp-updater:latest
UPDATE_AGENT_URL=http://updater:8080
UPDATE_HEALTH_TIMEOUT=180
DAILY_SETTLEMENT_BACKUP_INTERVAL_SECONDS=300
COMPOSE_PROJECT_NAME=fliegerlager
APP_HEALTH_URL=http://app:8000/healthz/
TARGET_SERVICE=app

PORTAINER_URL=https://portainer.example.org
PORTAINER_API_KEY=ptr_replace-with-dedicated-portainer-api-key
PORTAINER_ENDPOINT_ID=1
PORTAINER_STACK_ID=123
PORTAINER_VERIFY_SSL=true

APP_BIND_ADDRESS=127.0.0.1
APP_PORT=8000
BACKUP_DIR=./backups
# Optional. Public GHCR images do not need a token.
GHCR_TOKEN=
TZ=Europe/Berlin
